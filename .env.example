# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (for cron/API routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# INSEE Sirene API (free — register at https://portail-api.insee.fr)
# Old portal (api.insee.fr) was closed Sept 2025
INSEE_API_TOKEN=your-insee-token

# INPI RNE API (free — register at https://data.inpi.fr, activate "Accès APIs RNE")
INPI_USERNAME=your-inpi-email
INPI_PASSWORD=your-inpi-password

# DeepSeek API (cheap — register at https://platform.deepseek.com)
DEEPSEEK_API_KEY=your-deepseek-api-key
